# LLM Backend (ollama or llama_cpp or remote_api)
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

LLAMA_CPP_BASE_URL=http://localhost:8080/v1
LLAMA_CPP_MODEL=default

REMOTE_API_BASE_URL=https://api.openai.com/v1
REMOTE_API_KEY=

# SBQ-Quant external service (optional)
SBQ_QUANT_BASE_URL=http://localhost:8001

# FinGPT API (optional)
FINGPT_API_URL=http://localhost:8200

# RAG service (optional)
RAG_API_URL=http://localhost:8400

# ARAM FastAPI
ARAM_HOST=0.0.0.0
ARAM_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
